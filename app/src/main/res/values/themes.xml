<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme: no ActionBar, edge-to-edge WebView -->
    <style name="Theme.SmartShopping" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/bg_light</item>
        <item name="android:navigationBarColor">@color/bg_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
